# ============================================================
#  Local OCR & Dynamic RAG System — environment configuration
#  Copy this file to `.env` and fill in real values.
#  `.env` is gitignored and must NEVER be committed.
# ============================================================

# ---- OCR (Surya, fully local) ----------------------------
# Languages to recognise per page, as comma-separated ISO codes.
OCR_LANGS=bn,en

# ---- Answer generation (fully local) ---------------------
# LLM_MODE controls the final RAG synthesis step. Both options are 100% local —
# no external API is ever called.
#   local  -> synthesize a natural-language answer via a local Ollama model
#             (recommended). Requires Ollama running + `ollama pull qwen2.5:7b`.
#   none   -> no LLM: return the retrieved, cited chunks verbatim
#             (zero dependencies; works without Ollama).
LLM_MODE=local

# Ollama settings (used when LLM_MODE=local).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---- Storage paths ---------------------------------------
CHROMA_DIR=./data/chroma_db
SQLITE_PATH=./data/ingestion.db
UPLOAD_DIR=./data/uploads

# ---- Retrieval defaults ----------------------------------
DEFAULT_TOP_K=5
